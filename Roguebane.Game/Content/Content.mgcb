
#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#-------------------------------- References --------------------------------#


#-------------------------------- Fonts -------------------------------------#

#begin display.spritefont
/importer:FontDescriptionImporter
/processor:FontDescriptionProcessor
/build:display.spritefont

#begin mono.spritefont
/importer:FontDescriptionImporter
/processor:FontDescriptionProcessor
/build:mono.spritefont


